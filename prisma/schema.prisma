generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
}





enum Role {
  SUPER_ADMIN
  ADMIN
  ASSISTANT
  COACH
  PARENT
  ATHLETE
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
  BLOCKED
}

enum FileType {
  PROFILE_IMAGE
  DNI_PDF
  MEDICAL_RECORD
  CONTRACT
  OTHER
}





model User {
  id                    String              @id @default(uuid())

  
  
  
  username              String              @unique
  password              String              

  
  
  

  name                  String?
  lastname              String?
  dni                   String?

  gender                Gender?

  birthDate             DateTime?          

  phone                 String?

  address               String?

  
  
  

  status                UserStatus          @default(PENDING)

  lastLoginAt           DateTime?          
  failedLoginAttempts   Int                 @default(0)
  blockedUntil          DateTime?          

  userMemberships       UserMembership[]

  files                 UserFile[]


  createdAt             DateTime            @default(now())

  updatedAt             DateTime            @updatedAt

  available             Boolean             @default(true)

  
  
  

  @@index([status])

  @@index([available])

  @@map("users")
}



enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}


model UserFile {
  id            String      @id @default(uuid())

  userId        String     

  type          FileType

  url           String

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime    @default(now())

  updatedAt     DateTime    @updatedAt

  available     Boolean     @default(true)

  @@index([type])
  @@index([available])

  @@map("user_files")
}

model UserMembership {
  id            String            @id @default(cuid())

  userId        String
  assignmentId  String?           // null para SUPER_ADMIN y ADMIN

  role          Role

  status        MembershipStatus  @default(ACTIVE)

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, assignmentId, role])
  @@index([assignmentId])
  @@index([userId])
}